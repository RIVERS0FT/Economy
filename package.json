{
  "name": "economy",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "verify:architecture": "node scripts/verify-ui-architecture.mjs && node scripts/verify-liquid-glass-chrome.mjs",
    "test:nginx-config": "python3 scripts/test_configure_economy_nginx.py",
    "server:check": "node --check server/src/*.js",
    "server:test": "node --test server/test/*.test.js",
    "build": "npm run verify:architecture && npm run test:nginx-config && npm run server:check && npm run server:test && tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@tailwindcss/postcss": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "latest"
  }
}