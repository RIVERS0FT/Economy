# Root README and design authority updates.
path = 'README.md'
text = read(path)
text = replace_once(text, 'Economy 是一款网页端多人在线经济模拟、产业经营、统一资产交易与艺术藏品拍卖游戏。', 'Economy 是一款网页端多人在线经济模拟、产业经营、统一资产交易与藏品／商品／工厂竞价拍卖游戏。', path)
text = replace_once(text, '→ 参与唯一艺术藏品拍卖', '→ 通过拍卖交易藏品、商品和工厂', path)
text = replace_once(text, '- 藏品拍卖采用公开竞价；最高出价冻结资金，被超价时自动释放，结束后服务器自动结算资金并转移归属。', '- 藏品、商品和工厂均可采用公开竞价拍卖；卖方资产与最高出价资金同时冻结，被超价时自动释放资金，结束后服务器自动结算并转移资产。商品最高出价预占仓库，工厂拍卖冻结数量退出生产；拍卖成交价不写入订单簿行情或估值。', path)
text = replace_once(text, '- 拍卖：发起藏品拍卖、竞价、取消无出价拍卖和查看结算结果。', '- 拍卖：选择藏品、商品或工厂发起竞价，取消无出价拍卖并查看自动结算结果。', path)
text = replace_once(text, '| 礼品码、藏品、拍卖、封禁复核与管理员后台 | `docs/GIFT_CODE_AND_ADMIN_DESIGN.md` |', '| 礼品码、藏品、资产拍卖、封禁复核与管理员后台 | `docs/GIFT_CODE_AND_ADMIN_DESIGN.md` |', path)
write(path, text)

path = 'docs/README.md'
