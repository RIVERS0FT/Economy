for rel, spec in OPS.items():
    path=Path(rel)
    old=path.read_text() if path.exists() else ''
    if spec['before'] is not None and hashlib.sha256(old.encode()).hexdigest()!=spec['before']:
        raise SystemExit(f'before hash mismatch: {rel}')
    lines=old.splitlines(True)
    for start,end,text in reversed(spec['changes']):
        lines[start:end]=text.splitlines(True)
    new=''.join(lines)
    if hashlib.sha256(new.encode()).hexdigest()!=spec['after']:
        raise SystemExit(f'after hash mismatch: {rel}')
    path.parent.mkdir(parents=True,exist_ok=True)
    path.write_text(new)
print(f'Applied {len(OPS)} files')
